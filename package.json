    "@typescript-eslint/parser": "^8.59.0",
    "builtin-modules": "3.3.0",
    "esbuild": "0.17.3",
    "eslint": "^9.17.0",
    "eslint-plugin-obsidianmd": "^0.2.4",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4",
    "typescript-eslint": "^8.59.0"
  }
}
